const PlantDataContext = createContext(undefined);

function PlantDataProvider({ children }) {
  const [locations, setLocations] = useState([]);
  const [homeData, setHomeData] = useState(null);

  const [demoPlants, setDemoPlants] = useState(() => {
    return (DEMO_SEED.plants || []).map(p => {
      const gs = cleanDisplayName(`${p.genus || ''} ${p.species || p.taxon || ''}`.trim());
      const due = demoRecomputeDue_(p);
      return { ...p, gs, primary: demoPrimary_(p), due: due || '' };
    });
  });
  const [demoPhotoMap, setDemoPhotoMap] = useState(() => ({}));
  const [demoTimelineMap, setDemoTimelineMap] = useState(() => ({}));
  const [demoHomeData, setDemoHomeData] = useState(() => null);

  const demoRebuildHome_ = (plantsList) => {
    const today = new Date(); today.setHours(0,0,0,0);
    const in7 = new Date(today); in7.setDate(in7.getDate() + 7);

    const dueNow = [], upcoming = [];
    const fertDueNow = [], fertUpcoming = [];
    const bothDueNow = [], bothUpcoming = [];
    const birthdays = [];

    const parseDay = (iso) => {
      const d = new Date(String(iso || '').trim());
      if (isNaN(d)) return null;
      d.setHours(0,0,0,0);
      return d;
    };

    (plantsList || []).forEach(p => {
      const primary = p.primary || demoPrimary_(p);

      // Water due
      const waterDueStr = String(p.due || '').trim();
      const waterDueDate = waterDueStr ? parseDay(waterDueStr) : null;
      let waterBucket = '';
      if (waterDueDate) {
        if (waterDueDate <= today) {
          waterBucket = 'now';
          dueNow.push({ uid: p.uid, primary, due: waterDueStr });
        } else if (waterDueDate <= in7) {
          waterBucket = 'upcoming';
          upcoming.push({ uid: p.uid, primary, due: waterDueStr });
        }
      }

      // Fert due
      const fertDueStr = String(demoRecomputeFertDue_(p) || '').trim();
      const fertDueDate = fertDueStr ? parseDay(fertDueStr) : null;
      let fertBucket = '';
      if (fertDueDate) {
        if (fertDueDate <= today) {
          fertBucket = 'now';
          fertDueNow.push({ uid: p.uid, primary, due: fertDueStr });
        } else if (fertDueDate <= in7) {
          fertBucket = 'upcoming';
          fertUpcoming.push({ uid: p.uid, primary, due: fertDueStr });
        }
      }

      // Both (within 7 days for both)
      if (waterBucket && fertBucket) {
        const item = { uid: p.uid, primary, waterDue: waterDueStr || '', fertDue: fertDueStr || '' };
        if (waterBucket === 'now' && fertBucket === 'now') bothDueNow.push(item);
        else bothUpcoming.push(item);
      }

      const b = String(p.birthday || '').trim();
      if (b) birthdays.push(primary);
    });

    dueNow.sort((a,b) => String(a.due).localeCompare(String(b.due)));
    upcoming.sort((a,b) => String(a.due).localeCompare(String(b.due)));
    fertDueNow.sort((a,b) => String(a.due).localeCompare(String(b.due)));
    fertUpcoming.sort((a,b) => String(a.due).localeCompare(String(b.due)));
    bothDueNow.sort((a,b) => (String(a.waterDue||'') + '|' + String(a.fertDue||'')).localeCompare(String(b.waterDue||'') + '|' + String(b.fertDue||'')));
    bothUpcoming.sort((a,b) => (String(a.waterDue||'') + '|' + String(a.fertDue||'')).localeCompare(String(b.waterDue||'') + '|' + String(b.fertDue||'')));

    return {
      dueNow,
      upcoming,
      fertDueNow,
      fertUpcoming,
      bothDueNow,
      bothUpcoming,
      birthdays: birthdays.slice(0, 3),
      totalCount: (plantsList || []).length
    };
  };

  useEffect(() => {
    if (DEMO_MODE) { setDemoHomeData(demoRebuildHome_(demoPlants)); return; }
    gasCall('plantosListLocations').then(setLocations).catch(() => setLocations([]));
    gasCall('plantosHome').then(setHomeData).catch(() => setHomeData(null));
  }, []);

  useEffect(() => {
    if (!DEMO_MODE) return;
    setDemoHomeData(demoRebuildHome_(demoPlants));
  }, [demoPlants]);

  const refreshHome = async () => {
    if (DEMO_MODE) { const d = demoRebuildHome_(demoPlants); setDemoHomeData(d); return d; }
    const d = await gasCall('plantosHome');
    setHomeData(d);
    return d;
  };

  const demoFind_ = (uid) => (demoPlants || []).find(p => String(p.uid) === String(uid));
  const demoSetPlant_ = (uid, patch) => {
    setDemoPlants(prev => (prev || []).map(p => {
      if (String(p.uid) !== String(uid)) return p;
      const next = { ...p, ...(patch || {}) };
      next.primary = demoPrimary_(next);
      if (patch && (patch.everyDays || patch.lastWatered || patch.recomputeDue)) {
        next.due = demoRecomputeDue_(next) || next.due || '';
      }
      return next;
    }));
  };
  const demoPushLog_ = (uid, action, details) => {
    const item = { uid: String(uid), ts: demoNowStamp_(), action, details: String(details || '').trim() };
    setDemoTimelineMap(prev => {
      const next = { ...(prev || {}) };
      const arr = Array.isArray(next[uid]) ? next[uid].slice() : [];
      arr.unshift(item);
      next[uid] = arr.slice(0, 60);
      return next;
    });
  };

  const getPlantsByLocation = (location) => {
    if (DEMO_MODE) {
      const loc = String(location || '').trim();
      return Promise.resolve((demoPlants || []).filter(p => String(p.location || '') === loc));
    }
    return gasCall('plantosGetPlantsByLocation', location);
  };

  const getPlant = (uid) => {
    if (DEMO_MODE) {
      const p = demoFind_(uid);
      return Promise.resolve(p ? { ...p } : null);
    }
    return gasCall('plantosGetPlant', uid).then(res => (res && res.ok ? res.plant : null));
  };

  const setNickname = (uid, nickname) => {
    if (DEMO_MODE) {
      demoSetPlant_(uid, { nickname: String(nickname || '').trim() });
      demoPushLog_(uid, 'UPDATE', `Nickname: ${String(nickname || '').trim()}`);
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosSetNickname', uid, nickname);
  };

  const createPlant = (payload) => {
    if (DEMO_MODE) {
      const maxUid = (demoPlants || []).reduce((m,p)=>Math.max(m, Number(p.uid)||0), 69000000);
      const uid = String(maxUid + 1).padStart(8,'0');
      const g = String(payload.genus || '').trim();
      const t = String(payload.taxon || '').trim();
      const p = {
        uid, nickname: String(payload.nickname || '').trim(), genus: g, taxon: t, species: t,
        classification: String(payload.classification || '').trim(),
        location: String(payload.location || '').trim(),
        substrate: String(payload.medium || payload.substrate || '').trim(),
        medium: String(payload.medium || payload.substrate || '').trim(),
        potSize: String(payload.potSize || '').trim(),
        birthday: String(payload.birthday || '').trim(),
        everyDays: String(payload.everyDays || '').trim(),
        fertilizeEveryDays: String(payload.fertilizeEveryDays || '').trim(),
        lastWatered: '', lastFertilized: '', lastRepotted: '', notes: ''
      };
      p.gs = cleanDisplayName(`${p.genus} ${p.species}`.trim());
      p.primary = demoPrimary_(p);
      p.due = demoRecomputeDue_(p) || '';
      setDemoPlants(prev => [p, ...(prev || [])]);
      demoPushLog_(uid, 'CREATE', 'Created');
      return Promise.resolve({ ok: true, uid });
    }
    return gasCall('plantosCreatePlant', payload);
  };

  const updatePlant = (uid, patch) => {
    if (DEMO_MODE) {
      demoSetPlant_(uid, patch || {});
      demoPushLog_(uid, 'UPDATE', Object.keys(patch || {}).join(', '));
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosUpdatePlant', uid, patch || {});
  };

  const quickLog = (uid, payload) => {
    if (DEMO_MODE) {
      const p = demoFind_(uid);
      if (!p) return Promise.resolve({ ok: false });
      const notes = String(payload && payload.notes ? payload.notes : '').trim();
      if (payload && payload.water) {
        const today = demoIso_(new Date());
        demoSetPlant_(uid, { lastWatered: today, due: demoAddDays_(today, Number(p.everyDays||0)) });
        demoPushLog_(uid, 'WATER', notes || 'Watered');
      }
      if (payload && payload.fertilize) {
        const today = demoIso_(new Date());
        demoSetPlant_(uid, { lastFertilized: today });
        demoPushLog_(uid, 'FERTILIZE', notes || 'Fertilized');
      }
      if (payload && payload.repot) {
        const today = demoIso_(new Date());
        demoSetPlant_(uid, { lastRepotted: today, potSize: payload.potSize || p.potSize, substrate: payload.substrate || p.substrate, medium: payload.substrate || p.medium });
        demoPushLog_(uid, 'REPOT', notes || 'Repotted');
      }
      if (payload && payload.note && !payload.water && !payload.fertilize && !payload.repot) {
        demoPushLog_(uid, 'NOTE', notes || 'Note');
      }
      if (!payload.water && !payload.fertilize && !payload.repot && notes) {
        demoPushLog_(uid, 'NOTE', notes);
      }
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosQuickLog', uid, payload || {});
  };

  const batchWater = (uids, actionLabel) => {
    if (DEMO_MODE) {
      const label = String(actionLabel || 'Watered');
      (uids || []).forEach(uid => quickLog(uid, { water: true, fertilize: false, repot: false, notes: label }));
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosBatchWater', uids || [], actionLabel || '');
  };

  const batchFertilize = (uids, actionLabel) => {
    if (DEMO_MODE) {
      const label = String(actionLabel || 'Fertilized');
      (uids || []).forEach(uid => quickLog(uid, { water: false, fertilize: true, repot: false, notes: label }));
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosBatchFertilize', uids || [], actionLabel || '');
  };

  const getRecentLog = (limit) => {
    if (DEMO_MODE) {
      const all = [];
      Object.keys(demoTimelineMap || {}).forEach(uid => { (demoTimelineMap[uid] || []).forEach(it => all.push(it)); });
      all.sort((a,b) => String(b.ts).localeCompare(String(a.ts)));
      return Promise.resolve(all.slice(0, Number(limit) || 25));
    }
    return gasCall('plantosGetRecentLog', limit || 25);
  };

  const getTimeline = (uid, limit) => {
    if (DEMO_MODE) {
      const arr = (demoTimelineMap && demoTimelineMap[String(uid)]) ? demoTimelineMap[String(uid)] : [];
      return Promise.resolve(arr.slice(0, Number(limit) || 30));
    }
    return gasCall('plantosGetTimeline', uid, limit || 30);
  };

  const search = (q, limit) => {
    if (DEMO_MODE) {
      const qq = String(q || '').trim().toLowerCase();
      if (!qq) return Promise.resolve([]);
      const out = (demoPlants || []).filter(p => {
        const blob = [p.uid, p.nickname, p.primary, p.genus, p.species, p.taxon, p.classification, p.location, p.substrate, p.medium, p.gs].join(' ').toLowerCase();
        return blob.includes(qq);
      });
      return Promise.resolve(out.slice(0, Number(limit) || 15));
    }
    return gasCall('plantosSearch', q, limit || 15);
  };

  const getLatestPhoto = (uid) => {
    if (DEMO_MODE) {
      const ph = demoPhotoMap[String(uid)];
      if (ph) return Promise.resolve({ ok: true, photo: ph });
      return Promise.resolve({ ok: false });
    }
    return gasCall('plantosGetLatestPhoto', uid);
  };

  const uploadPlantPhoto = (uid, dataUrl, originalName) => {
    if (DEMO_MODE) {
      const du = String(dataUrl || '');
      setDemoPhotoMap(prev => ({ ...(prev || {}), [String(uid)]: { thumbUrl: du, viewUrl: du, name: originalName || 'photo' } }));
      demoPushLog_(uid, 'UPDATE', 'Photo added');
      return Promise.resolve({ ok: true });
    }
    return gasCall('plantosUploadPlantPhoto', uid, dataUrl, originalName);
  };

  const ctxValue = DEMO_MODE ? {
    locations: DEMO_SEED.locations || [], homeData: demoHomeData, refreshHome,
    getPlantsByLocation, getPlant, getTimeline, getRecentLog,
    createPlant, updatePlant, setNickname,
    quickLog, batchWater, batchFertilize, search, getLatestPhoto, uploadPlantPhoto
  } : {
    locations, homeData, refreshHome, getPlantsByLocation, getPlant, setNickname,
    createPlant, updatePlant, quickLog, batchWater, batchFertilize,
    getRecentLog, getTimeline, search, getLatestPhoto, uploadPlantPhoto
  };

  return <PlantDataContext.Provider value={ctxValue}>{children}</PlantDataContext.Provider>;
}

function usePlantData() {
  const ctx = useContext(PlantDataContext);
  if (!ctx) throw new Error('usePlantData must be used within PlantDataProvider');
  return ctx;
}

