      {/* ── Main content — fills between top and bottom nav ── */}
      <div className="scroll-y"
        style={{ flex:1, minHeight:0, position:'relative', zIndex:10, overflowY:'auto',
          paddingTop: isDesktop ? 0 : 4 }}>
        {render()}
      </div>

      {/* ── Ticker (home only) ── */}
      {currentScreen === 'home' && <div style={{ position:'relative', zIndex:20 }}><Ticker /></div>}

      {/* ── Bottom nav (mobile only) ── */}
      <BottomNav current={currentScreen} navigate={navigate} goBack={goBack} />
    </div>
  );
}

/* ── GAS Banner tip (shows once, then dismissed) ── */
function GasBannerTip() {
  const { isMobile } = useScreenSize();
  const [visible, setVisible] = React.useState(true);
  if (!isMobile || !visible || !HAS_GAS) return null;
  const pxS = { fontFamily:"'Pixelify Sans', cursive" };
  return (
    <div style={{
      position:'fixed', bottom: 72, left: 8, right: 8, zIndex: 999,
      background:'#1a0900', border:'3px solid #8BB55C', borderRadius:12,
      padding:'10px 14px', display:'flex', alignItems:'center', gap:10,
      boxShadow:'0 4px 20px rgba(0,0,0,0.5)'
    }}>
      <span style={{ fontSize:22 }}>📱</span>
      <div style={{ flex:1 }}>
        <div style={{ ...pxS, fontSize:'11px', color:'#8BB55C', fontWeight:900, marginBottom:2 }}>TIP: Add to Home Screen</div>
        <div style={{ ...pxS, fontSize:'10px', color:'#C8B488', lineHeight:1.4 }}>
          Share → Add to Home Screen for a full-screen app experience without the Google banner.
        </div>
      </div>
      <button type="button" onClick={() => setVisible(false)}
        style={{ ...pxS, fontSize:'18px', color:'#8B6040', background:'none', border:'none', padding:'0 4px', cursor:'pointer' }}>✕</button>
    </div>
  );
}


function PlantOSApp() {
  return (
    <NavigationProvider>
      <PlantDataProvider>
        <AppContent />
        <GasBannerTip />
      </PlantDataProvider>
    </NavigationProvider>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<PlantOSApp />);
</script>
</body>
</html>
