/* ===================== ADD PLANT ===================== */
function AddScreen() {
  const { goBack, navigate } = useNavigation();
  const { locations, createPlant } = usePlantData();
  const { isSmall, isDesktop } = useScreenSize();

  const [nickname, setNickname] = useState('');
  const [genus, setGenus] = useState('');
  const [taxon, setTaxon] = useState('');
  const [location, setLocation] = useState('');
  const [showOptional, setShowOptional] = useState(false);
  const [birthday, setBirthday] = useState('');
  const [medium, setMedium] = useState('');
  const [potSize, setPotSize] = useState('');
  const [waterEveryDays, setWaterEveryDays] = useState('');
  const [fertilizeEveryDays, setFertilizeEveryDays] = useState('');
  const [status, setStatus] = useState(null);

  function requiredOk() {
    const hasName = String(nickname || '').trim() || String(genus || '').trim() || String(taxon || '').trim();
    return !!(hasName && String(location || '').trim());
  }

  async function submit() {
    if (!requiredOk()) {
      setStatus({ type:'error', message:'Need at least a name (nickname or genus/species) + a location.' });
      setTimeout(() => setStatus(null), 2200);
      return;
    }
    setStatus({ type:'loading', message:'Creating plant...' });
    try {
      const payload = {
        nickname: String(nickname || '').trim(),
        genus:    String(genus    || '').trim(),
        taxon:    String(taxon    || '').trim(),
        location: String(location || '').trim(),
        birthday: String(birthday || '').trim(),
        medium:   String(medium   || '').trim(),
        substrate:String(medium   || '').trim(),
        potSize:  String(potSize  || '').trim(),
        everyDays:          String(waterEveryDays      || '').trim(),
        fertilizeEveryDays: String(fertilizeEveryDays  || '').trim(),
      };
      const res = await createPlant(payload);
      const uid = res && res.uid ? String(res.uid) : '';
      setStatus({ type:'success', message:'Added ✅' });
      setTimeout(() => { setStatus(null); if (uid) navigate('plant', { uid }); else navigate('home'); }, 900);
    } catch (e) {
      setStatus({ type:'error', message: (e && e.message) ? e.message : 'Failed' });
      setTimeout(() => setStatus(null), 2200);
    }
  }

  const pxS = { fontFamily:"'Pixelify Sans', cursive" };

  return (
    <div className={`flex flex-col ${isSmall ? 'p-3' : isDesktop ? 'p-6' : 'p-4'} w-full pb-4 fade-in`}
      style={{ maxWidth: isDesktop ? '1100px' : '680px', margin: '0 auto' }}>
      <PlantCard title="ADD PLANT">
        {status && <StatusMessage type={status.type} message={status.message} />}
        <div className="space-y-3">
          <div>
            <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>Nickname (optional)</div>
            <input value={nickname} onChange={e => setNickname(e.target.value)}
              className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
              style={{ ...pxS, fontSize:'14px', color:'#4A3020' }} placeholder="e.g., 'Giga Chad'" />
          </div>
          <div className="grid grid-cols-2 gap-2">
            <div>
              <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>Genus</div>
              <input value={genus} onChange={e => setGenus(e.target.value)}
                className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
                style={{ ...pxS, fontSize:'14px', color:'#4A3020' }} placeholder="e.g., Alocasia" />
            </div>
            <div>
              <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>Species / Taxon</div>
              <input value={taxon} onChange={e => setTaxon(e.target.value)}
                className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
                style={{ ...pxS, fontSize:'14px', color:'#4A3020' }} placeholder="e.g., baginda" />
            </div>
          </div>
          <div>
            <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>Location (required)</div>
            <select value={location} onChange={e => setLocation(e.target.value)}
              className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
              style={{ ...pxS, fontSize:'14px', color:'#4A3020' }}>
              <option value="">— Select —</option>
              {locations.map(loc => (<option key={loc} value={loc}>{loc}</option>))}
            </select>
          </div>
          <button type="button" onClick={() => setShowOptional(v => !v)} className="underline"
            style={{ ...pxS, fontSize:'12px', color:'#4A3020' }}>
            {showOptional ? 'Hide optional fields' : 'Show optional fields'}
          </button>
          {showOptional && (
            <div className="space-y-3 border-2 border-[#C8B488] rounded-lg p-3 bg-white">
              <div>
                <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>DOB (optional)</div>
                <input value={birthday} onChange={e => setBirthday(e.target.value)}
                  className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
                  style={{ ...pxS, fontSize:'14px', color:'#4A3020' }} placeholder="YYYY-MM-DD" />
              </div>
              <div>
                <div style={{ ...pxS, fontSize:'12px', fontWeight:700, color:'#4A3020' }}>Substrate / Medium (optional)</div>
                <input value={medium} onChange={e => setMedium(e.target.value)}
                  className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
