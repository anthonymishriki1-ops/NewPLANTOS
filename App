          </div>
        </div>
      </PlantCard>
    </div>
  );
}

/* ===================== MY PLANTS ===================== */
function MyPlantsScreen() {
  const { goBack, navigate } = useNavigation();
  const { locations, getPlantsByLocation, getLatestPhoto, updatePlant, setNickname, search } = usePlantData();
  const { isSmall, isDesktop } = useScreenSize();
  const [selectedLoc, setSelectedLoc] = useState('');
  const [plants, setPlants] = useState([]);
  const [loading, setLoading] = useState(false);
  const [thumbs, setThumbs] = useState({});
  const [plantFilter, setPlantFilter] = useState('');
  const [globalQ, setGlobalQ] = useState('');
  const [globalResults, setGlobalResults] = useState([]);
  const [globalLoading, setGlobalLoading] = useState(false);
  const globalTicketRef = useRef(0);
  const [editUid, setEditUid] = useState('');
  const [edit, setEdit] = useState({});
  const [editStatus, setEditStatus] = useState(null);

  useEffect(() => {
    let alive = true;
    (async () => {
      if (!selectedLoc) { setPlants([]); setPlantFilter(''); setEditUid(''); return; }
      setLoading(true);
      try {
        const ps = await getPlantsByLocation(selectedLoc);
        const counts = {};
        (ps || []).forEach(p => { const key = String(p.classification || '').trim().toLowerCase(); if (!key) return; counts[key] = (counts[key] || 0) + 1; });
        const dupIndex = {};
        Object.keys(counts).forEach(k => { dupIndex[k] = 1; });
        const processed = (ps || []).map(p => {
          const cls0 = String(p.classification || '').trim();
          let cls = cls0;
          const key = String(cls0 || '').trim().toLowerCase();
          if (!p.nickname && key && counts[key] > 1) { const idx = dupIndex[key]++; cls = `${cls0} (#${idx})`; }
          const title = p.nickname ? String(p.nickname).trim() : (cls || p.gs || p.uid);
          const tax = p.nickname ? (p.gs || cls0 || '') : '';
          const line2 = [tax, p.location].filter(Boolean).join(' • ');
          return { ...p, _title: title, _tax: tax, _line2: line2 };
        });
        if (!alive) return;
        setPlants(processed);
      } catch(e) { if (!alive) return; setPlants([]); }
      finally { if (alive) setLoading(false); }
    })();
    return () => { alive = false; };
  }, [selectedLoc]);

  useEffect(() => {
    let alive = true;
    (async () => {
      const list = [...(plants || []), ...(globalResults || [])];
      const next = {};
      for (let i=0;i<list.length;i++){
        const uid = String(list[i].uid || '');
        if (!uid) continue; if (thumbs[uid] || next[uid]) continue;
        try { const res = await getLatestPhoto(uid); if (res && res.ok && res.photo && res.photo.thumbUrl) next[uid] = res.photo.thumbUrl; } catch(e){}
      }
      if (!alive) return;
      if (Object.keys(next).length) setThumbs(prev => ({ ...prev, ...next }));
    })();
    return () => { alive = false; };
  }, [plants, globalResults]);

  function openPlant(uid){ navigate('plant', { uid }); }

  useEffect(() => {
    let alive = true;
    const qq = String(globalQ || '').trim();
    const ticket = ++globalTicketRef.current;
    if (!qq) { setGlobalLoading(false); setGlobalResults([]); return () => { alive = false; }; }
    setGlobalLoading(true);
    (async () => {
      try {
        const res = await search(qq, 25);
        if (!alive) return; if (ticket !== globalTicketRef.current) return;
        setGlobalResults(res || []);
      } catch (e) { if (!alive) return; if (ticket !== globalTicketRef.current) return; setGlobalResults([]); }
      finally { if (!alive) return; if (ticket !== globalTicketRef.current) return; setGlobalLoading(false); }
    })();
    return () => { alive = false; };
  }, [globalQ]);

  const filteredPlants = useMemo(() => {
    const q = normStr(plantFilter);
    if (!q) return plants;
    return (plants || []).filter(p => {
      const hay = [p._title, p._tax, p._line2, p.uid, p.genus, p.species, p.taxon, p.classification].map(x => String(x||'')).join(' • ').toLowerCase();
      return hay.includes(q);
    });
  }, [plantFilter, plants]);

  function openEdit(p){ setEditUid(String(p.uid || '')); setEdit({ nickname: p.nickname || '', location: p.location || '', potSize: p.potSize || '', substrate: p.substrate || p.medium || '', genus: p.genus || '', taxon: p.species || p.taxon || '', classification: p.classification || '', everyDays: p.everyDays || '', fertilizeEveryDays: p.fertilizeEveryDays || '', birthday: p.birthday || '' }); setEditStatus(null); }
  function closeEdit(){ setEditUid(''); setEdit({}); setEditStatus(null); }

  async function saveEdit(){
    if (!editUid) return;
    setEditStatus({ type:'loading', message:'Saving...' });
    try {
      const nn = String(edit.nickname || '').trim();
      if (nn) await setNickname(editUid, nn);
      else await updatePlant(editUid, { nickname: '' });
      await updatePlant(editUid, {
        location: String(edit.location||'').trim(), potSize: String(edit.potSize||'').trim(),
        substrate: String(edit.substrate||'').trim(), genus: String(edit.genus||'').trim(),
        taxon: String(edit.taxon||'').trim(), classification: String(edit.classification||'').trim(),
        everyDays: String(edit.everyDays||'').trim(), fertilizeEveryDays: String(edit.fertilizeEveryDays||'').trim(),
        birthday: String(edit.birthday||'').trim(), recomputeDue: true
      });
      setEditStatus({ type:'success', message:'Saved ✅' });
      const qq = String(globalQ || '').trim();
      if (qq) { try { const res = await search(qq, 25); setGlobalResults(res || []); } catch (e) { setGlobalResults([]); } }
      if (selectedLoc) {
        const ps = await getPlantsByLocation(selectedLoc);
        const processed = (ps || []).map(p => { const cls0 = String(p.classification || '').trim(); const title = p.nickname ? String(p.nickname).trim() : (p.gs || cls0 || p.uid); const tax = p.gs || cls0 || ''; const line2 = [p.nickname ? tax : '', p.location].filter(Boolean).join(' • '); return { ...p, _title: title, _tax: tax, _line2: line2 }; });
        setPlants(processed);
      }
      setTimeout(() => setEditStatus(null), 900);
    } catch(e){ setEditStatus({ type:'error', message:'Failed' }); setTimeout(() => setEditStatus(null), 1500); }
  }

  const pxS = { fontFamily:"'Pixelify Sans', cursive" };

  return (
    <div className={`flex flex-col ${isSmall ? 'p-3' : isDesktop ? 'p-6' : 'p-4'} w-full pb-4 fade-in`}
      style={{ maxWidth: isDesktop ? '1100px' : '680px', margin: '0 auto' }}>
      <PlantCard title="MY PLANTS">
        <div className="mb-3">
          <input value={globalQ} onChange={e => setGlobalQ(e.target.value)} placeholder="Search all plants..."
            className="w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white input-depth"
            style={{ ...pxS, fontSize:'14px', color:'#4A3020' }} />
        </div>

        {globalQ.trim() ? (
