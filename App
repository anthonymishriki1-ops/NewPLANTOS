              </div>
              <div>
                <label className="block text-[#4A3020] mb-1" style={{ fontFamily:"'Press Start 2P', cursive", fontSize:'10px' }}>Pot Size (optional)</label>
                <select value={potSize} onChange={e => setPotSize(e.target.value)}
                  className="w-full p-3 rounded-lg border-4 border-[#6B4423] bg-white"
                  style={{ ...pxS, fontSize:'14px' }}>
                  <option value="">—</option>
                  {['2"','3"','4"','5"','6"','7"','8"','10"','12"'].map(s => <option key={s} value={s}>{s}</option>)}
                </select>
              </div>
              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="block text-[#4A3020] mb-1" style={{ fontFamily:"'Press Start 2P', cursive", fontSize:'10px' }}>Water Every (days)</label>
