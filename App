    .btn-gradient:hover::before { left: 100%; }

    .emoji-hover { display: inline-block; transition: transform 0.2s ease; }
    .emoji-hover:hover { transform: scale(1.18) rotate(6deg); }

    .bg-transition { transition: background-color 0.25s ease, border-color 0.25s ease; }

    .plant-item { transition: all 0.18s ease; }
    .plant-item:hover { background: linear-gradient(135deg, #F4E4C1 0%, #F8EDD5 100%); border-color: #6B9C3D !important; transform: translateX(4px); }

