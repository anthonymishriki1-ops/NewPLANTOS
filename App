  const { isSmall, isDesktop } = useScreenSize();

  const [tab, setTab] = useState('water'); // water | fert | both
  const [selected, setSelected] = useState({});
  const [status, setStatus] = useState(null);

  // Filters
  const [locFilter, setLocFilter] = useState('');        // '' = All
  const [subPreset, setSubPreset] = useState('');        // '' = All
  const [subContains, setSubContains] = useState('');    // free-text contains
  const [metaByUid, setMetaByUid] = useState({});        // uid -> { location, subText }
  const [metaLoading, setMetaLoading] = useState(false);

  const SUB_PRESETS = useMemo(() => ([
    { label:'All',        key:'',          aliases:[] },
    { label:'Semi-Hydro', key:'semihydro', aliases:['semi hydro','semi-hydro','semihydro','pon','leca','hydroton','expanded clay','clay ball','stratum','fluval stratum','lava rock','pumice','perlite','zeolite'] },
    { label:'Soil',       key:'soil',      aliases:['soil','potting','potting mix','mix','soil mix','promix','peat','peat moss','compost','worm cast','castings','manure','humus'] },
    { label:'Coco',       key:'coco',      aliases:['coco','coir','coconut','coconut coir'] },
    { label:'Bark',       key:'bark',      aliases:['bark','orchid','orchid bark','pine bark','fir bark','chunk','chunks'] },
    { label:'Mineral',    key:'mineral',   aliases:['mineral','pumice','perlite','lava','lava rock','scoria','grit','sand','akadama','kanuma','zeolite','diatomite','calcined clay','turface'] },
  ]), []);

  const pxS = { fontFamily:"'Pixelify Sans', cursive" };
  const px8S = { fontFamily:"'Press Start 2P', cursive", fontSize:'10px' };

  function normalizeSubText(p) {
    const a = String((p && p.substrate) ? p.substrate : '').trim();
    const b = String((p && p.medium) ? p.medium : '').trim();
    return (a + ' ' + b).trim().toLowerCase();
  }

  // DEMO: preload metadata instantly from the seed.
  useEffect(() => {
    if (!DEMO_MODE) return;
    try {
      const map = {};
      (DEMO_SEED && DEMO_SEED.plants ? DEMO_SEED.plants : []).forEach(p => {
        const uid = String(p && p.uid ? p.uid : '').trim();
        if (!uid) return;
        map[uid] = { location: String(p.location || '').trim(), subText: normalizeSubText(p) };
      });
      setMetaByUid(map);
    } catch (e) {}
  }, []);

  useEffect(() => { refreshHome().catch(()=>{}); }, []);
  useEffect(() => { setSelected({}); setStatus(null); }, [tab]);

  const waterNow = (homeData && homeData.dueNow) ? homeData.dueNow : [];
  const waterUpcoming = (homeData && homeData.upcoming) ? homeData.upcoming : [];

  const fertNow = (homeData && homeData.fertDueNow) ? homeData.fertDueNow : [];
  const fertUpcoming = (homeData && homeData.fertUpcoming) ? homeData.fertUpcoming : [];

  const bothNow = (homeData && homeData.bothDueNow) ? homeData.bothDueNow : [];
  const bothUpcoming = (homeData && homeData.bothUpcoming) ? homeData.bothUpcoming : [];

  const fertDueByUid = useMemo(() => {
    const m = {};
    [...fertNow, ...fertUpcoming].forEach(x => { if (x && x.uid) m[String(x.uid)] = String(x.due || '').trim(); });
    return m;
  }, [fertNow, fertUpcoming]);

  const waterDueByUid = useMemo(() => {
    const m = {};
    [...waterNow, ...waterUpcoming].forEach(x => { if (x && x.uid) m[String(x.uid)] = String(x.due || '').trim(); });
    return m;
  }, [waterNow, waterUpcoming]);

  const fertSoonSet = useMemo(() => new Set(Object.keys(fertDueByUid)), [fertDueByUid]);
  const waterSoonSet = useMemo(() => new Set(Object.keys(waterDueByUid)), [waterDueByUid]);

  const tabLists = useMemo(() => {
    if (tab === 'fert') return { nowList: fertNow, upcomingList: fertUpcoming };
    if (tab === 'both') return { nowList: bothNow, upcomingList: bothUpcoming };
    return { nowList: waterNow, upcomingList: waterUpcoming };
  }, [tab, waterNow, waterUpcoming, fertNow, fertUpcoming, bothNow, bothUpcoming]);

  const nowListRaw = tabLists.nowList || [];
  const upcomingListRaw = tabLists.upcomingList || [];

  // Load metadata (GAS) for all plants shown on this screen so filters can work reliably.
  useEffect(() => {
    if (DEMO_MODE) return;
    let alive = true;

    const want = Array.from(new Set(
      [...nowListRaw, ...upcomingListRaw]
        .map(p => String(p && p.uid ? p.uid : '').trim())
        .filter(Boolean)
    ));

    const missing = want.filter(uid => !metaByUid[uid]);
    if (!missing.length) return;

    async function mapLimit(items, limit, fn) {
      const out = [];
      let idx = 0;
      const workers = new Array(Math.min(limit, items.length)).fill(0).map(async () => {
        while (idx < items.length) {
          const cur = items[idx++];
          out.push(await fn(cur));
        }
      });
      await Promise.all(workers);
      return out;
    }

    (async () => {
      setMetaLoading(true);
      try {
        const pairs = await mapLimit(missing, 6, async (uid) => {
          try {
            const p = await getPlant(uid);
            if (!p) return null;
            return [String(p.uid), { location: String(p.location || '').trim(), subText: normalizeSubText(p) }];
          } catch (e) {
            return null;
          }
        });
        if (!alive) return;
        const patch = {};
        (pairs || []).forEach(x => { if (x && x[0]) patch[x[0]] = x[1]; });
        if (Object.keys(patch).length) setMetaByUid(prev => ({ ...prev, ...patch }));
      } finally {
        if (alive) setMetaLoading(false);
      }
    })();

    return () => { alive = false; };
  }, [tab, nowListRaw, upcomingListRaw]);

  function matchesSubFilters(meta) {
    if (!meta) return false;
    const locOk = !locFilter || String(meta.location || '').trim().toLowerCase() === String(locFilter).trim().toLowerCase();

    const txt = String(meta.subText || '').toLowerCase();
    const free = String(subContains || '').trim().toLowerCase();

    const preset = SUB_PRESETS.find(x => x.key === subPreset);
    const presetOk = !subPreset || (preset ? preset.aliases.some(a => txt.includes(String(a).toLowerCase())) : true);
    const freeOk = !free || txt.includes(free);

    return locOk && presetOk && freeOk;
  }

  const filtersActive = !!(locFilter || subPreset || String(subContains || '').trim());

  const nowList = useMemo(() => {
    if (!filtersActive) return nowListRaw;
    return (nowListRaw || []).filter(p => {
      const uid = String(p && p.uid ? p.uid : '').trim();
      if (!uid) return false;
      const meta = metaByUid[uid];
      return matchesSubFilters(meta);
    });
  }, [filtersActive, nowListRaw, metaByUid, locFilter, subPreset, subContains]);

  const upcomingList = useMemo(() => {
    if (!filtersActive) return upcomingListRaw;
    return (upcomingListRaw || []).filter(p => {
      const uid = String(p && p.uid ? p.uid : '').trim();
      if (!uid) return false;
      const meta = metaByUid[uid];
      return matchesSubFilters(meta);
    });
  }, [filtersActive, upcomingListRaw, metaByUid, locFilter, subPreset, subContains]);

  // Keep selection in sync: if filters hide a plant, drop it from selection (prevents "hidden selected" surprises).
  useEffect(() => {
    const visible = new Set(
      [...nowList, ...upcomingList].map(p => String(p && p.uid ? p.uid : '').trim()).filter(Boolean)
    );
    setSelected(prev => {
      const next = {};
      Object.keys(prev || {}).forEach(uid => {
        if (prev[uid] && visible.has(uid)) next[uid] = true;
      });
      return next;
    });
  }, [tab, nowList, upcomingList]);

  const selectedUids = useMemo(() => Object.keys(selected).filter(k => selected[k]), [selected]);

  function toggle(uid) {
    const k = String(uid || '').trim();
    if (!k) return;
    setSelected(prev => ({ ...prev, [k]: !prev[k] }));
  }

  function selectAll(list) {
    const all = {};
    (list || []).forEach(p => { if (p && p.uid) all[String(p.uid)] = true; });
    setSelected(all);
  }

  function clearAll() { setSelected({}); }

  function clearFilters() {
    setLocFilter('');
    setSubPreset('');
    setSubContains('');
  }

  async function applySelected() {
    if (!selectedUids.length) return;
    const label = tab === 'fert' ? 'Fertilized' : 'Watered';
    const what = tab === 'fert' ? 'fertilize' : tab === 'both' ? 'water + fertilize' : 'water';
    setStatus({ type:'loading', message:`Logging ${what}...` });
    try {
      if (tab === 'water') await batchWater(selectedUids, label);
      else if (tab === 'fert') await batchFertilize(selectedUids, label);
      else {
        await batchWater(selectedUids, 'Watered');
        await batchFertilize(selectedUids, 'Fertilized');
      }
      await refreshHome().catch(()=>{});
      setSelected({});
      setStatus({ type:'success', message:'Saved ✅' });
      setTimeout(() => setStatus(null), 1100);
    } catch (e) {
      setStatus({ type:'error', message:'Failed' });
      setTimeout(() => setStatus(null), 1600);
    }
  }

  function Row({ p, bucket }) {
    const uid = String(p && p.uid ? p.uid : '');
    const primary = p && p.primary ? p.primary : uid;
    const checked = !!selected[uid];

    const dateStyleNow = { ...pxS, color:'#c0392b', fontWeight:900 };
    const dateStyleUpcoming = { ...pxS, color:'#2A4A1A', fontWeight:900 };
    const dateStyle = bucket === 'now' ? dateStyleNow : dateStyleUpcoming;

    const otherHint = (() => {
      if (!uid) return '';
      if (tab === 'water' && fertSoonSet.has(uid)) return `🌾 due ${fertDueByUid[uid] || ''}`.trim();
      if (tab === 'fert' && waterSoonSet.has(uid)) return `💧 due ${waterDueByUid[uid] || ''}`.trim();
      return '';
    })();

    const meta = metaByUid[uid] || null;
    const metaLine = meta
      ? [meta.location ? `📍 ${meta.location}` : '', meta.subText ? `🧱 ${meta.subText}` : ''].filter(Boolean).join('  •  ')
      : '';

    return (
      <div
        className={`bg-white border-2 border-[#C8B488] rounded-lg px-3 py-2 flex items-center gap-3 ${checked ? 'ring-2 ring-[#6B9C3D]' : ''}`}
        style={{ cursor:'pointer' }}
        onClick={() => toggle(uid)}
      >
        <div className="min-w-0 flex-1">
          <div style={{ ...pxS, fontWeight:900, color:'#4A3020' }} className="truncate">{primary}</div>

          {tab !== 'both' && otherHint && (
            <div style={{ ...pxS, fontSize:'11px', color:'#6B4423', fontWeight:800 }} className="truncate">{otherHint}</div>
          )}

          {filtersActive && metaLine && (
            <div style={{ ...pxS, fontSize:'10px', color:'#8B6040', fontWeight:800 }} className="truncate">
              {metaLine}
            </div>
          )}
        </div>

        <div className="flex items-center gap-2 shrink-0">
          {tab === 'both' ? (
            <div className="flex flex-col items-end leading-tight">
              <div style={{ ...pxS, fontSize:'11px', fontWeight:900, color:'#2A4A1A' }}>💧 {p.waterDue || '—'}</div>
              <div style={{ ...pxS, fontSize:'11px', fontWeight:900, color:'#7d4e00' }}>🌾 {p.fertDue || '—'}</div>
            </div>
          ) : (
            <div style={{ ...dateStyle, fontSize:'12px' }}>{p.due || '—'}</div>
          )}

          <input
            type="checkbox"
            className="w-5 h-5"
            checked={checked}
            onChange={() => toggle(uid)}
            onClick={(e) => e.stopPropagation()}
            title="Select"
          />
        </div>
      </div>
    );
  }

  const pad = isSmall ? 'p-3' : isDesktop ? 'p-6' : 'p-4';

  const TabButton = ({ id, label, icon }) => {
    const active = tab === id;
    return (
      <button
        type="button"
        onClick={() => setTab(id)}
        className={`flex-1 px-3 py-2 rounded-lg border-4 ${active ? 'bg-[#6B9C3D] border-[#4A7A1A] text-white' : 'bg-white border-[#C8B488] text-[#4A3020]'}`}
        style={{ ...pxS, fontWeight:900, fontSize:'12px' }}
      >
        {icon} {label}
      </button>
    );
  };

  const empty = nowList.length === 0 && upcomingList.length === 0;

  const totalRaw = (nowListRaw.length + upcomingListRaw.length);
  const totalShown = (nowList.length + upcomingList.length);

  return (
    <div className={`flex flex-col ${pad} w-full pb-4 fade-in`}
      style={{ maxWidth: isDesktop ? '1100px' : '680px', margin: '0 auto' }}>
      <PlantCard title="CARE DUE">
        {status && <StatusMessage type={status.type} message={status.message} />}

        {/* Tabs */}
        <div className="grid grid-cols-3 gap-2 mb-3">
          <TabButton id="water" label="Water" icon="💧" />
          <TabButton id="fert" label="Fertilize" icon="🌾" />
          <TabButton id="both" label="Both" icon="💧🌾" />
        </div>

        {/* Filters */}
        <div className="bg-white rounded-xl border-2 border-[#C8B488] shadow-sm p-3 mb-3">
          <div style={{ ...px8S, color:'#4A3020', marginBottom:'8px' }}>FILTERS</div>

          <div className="flex flex-col sm:flex-row gap-3 sm:items-end sm:justify-between">
            <div className="flex-1">
              <div style={{ ...pxS, fontSize:'12px', fontWeight:900, color:'#4A3020' }}>Location</div>
              <select
                value={locFilter}
                onChange={e => setLocFilter(e.target.value)}
                className="mt-1 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
                style={{ ...pxS, fontSize:'14px', color:'#4A3020' }}
              >
                <option value="">All</option>
                {(locations || []).map(loc => (<option key={loc} value={loc}>{loc}</option>))}
              </select>
            </div>

            <button
              type="button"
              onClick={clearFilters}
              className="underline"
              style={{ ...pxS, fontSize:'12px', color:'#4A3020', fontWeight:900 }}
            >
              Clear filters
            </button>
          </div>

          <div className="mt-3">
            <div style={{ ...pxS, fontSize:'12px', fontWeight:900, color:'#4A3020' }}>Medium</div>
            <div className="mt-1 flex flex-wrap gap-2">
              {SUB_PRESETS.map(p => {
                const active = subPreset === p.key;
                return (
                  <button
                    key={p.key || 'all'}
                    type="button"
                    onClick={() => setSubPreset(p.key)}
                    className={`px-3 py-2 rounded-lg border-4 ${active ? 'bg-[#7BB5CC] border-[#5A8C9D] text-[#1A3A4A]' : 'bg-white border-[#C8B488] text-[#4A3020]'}`}
                    style={{ ...pxS, fontWeight:900, fontSize:'12px' }}
                  >
                    {p.label}
                  </button>
                );
              })}
            </div>

            <input
              value={subContains}
              onChange={e => setSubContains(e.target.value)}
              placeholder="Optional: substrate contains… (pon, leca, soil mix)"
              className="mt-2 w-full border-4 border-[#6B4423] rounded-lg p-2 bg-white"
              style={{ ...pxS, fontSize:'13px', color:'#4A3020' }}
            />

            {filtersActive && (
              <div className="mt-2 flex items-center justify-between gap-2 flex-wrap">
                <div style={{ ...pxS, fontSize:'12px', color:'#4A3020', fontWeight:900 }}>
                  Showing {totalShown} of {totalRaw}
                </div>
                {metaLoading && (
                  <div style={{ ...pxS, fontSize:'12px', color:'#8B6040', fontWeight:800 }}>
                    Loading filter data…
                  </div>
                )}
              </div>
            )}
          </div>
        </div>

        {/* Selection actions */}
        <div className="flex items-center justify-between gap-2 mb-3 flex-wrap">
          <div style={{ ...pxS, fontSize:'12px', color:'#4A3020', fontWeight:900 }}>
            Selected: {selectedUids.length}
          </div>
          <div className="flex gap-3">
            <button type="button" onClick={() => selectAll(nowList)} className="underline"
              style={{ ...pxS, fontSize:'12px', color:'#4A3020', fontWeight:900 }}>
              Select Due Now
            </button>
            <button type="button" onClick={clearAll} className="underline"
              style={{ ...pxS, fontSize:'12px', color:'#4A3020', fontWeight:900 }}>
              Clear
            </button>
          </div>
        </div>

        {empty && (
          <StatusMessage
            type="info"
            message={tab === 'fert'
              ? 'No plants due for fertilizer right now.'
              : tab === 'both'
                ? 'No plants due for both within 7 days.'
                : 'No plants due for water right now.'}
          />
        )}

        {nowList.length > 0 && (
          <div className="mb-3">
            <div style={{ ...pxS, fontWeight:900, color:'#4A3020' }}>Due now</div>
            <div className="mt-2 space-y-2">
              {nowList.map(p => (<Row key={p.uid} p={p} bucket="now" />))}
            </div>
          </div>
        )}

        {upcomingList.length > 0 && (
          <div className="mb-3">
            <div style={{ ...pxS, fontWeight:900, color:'#4A3020' }}>Upcoming (7 days)</div>
            <div className="mt-2 space-y-2">
              {upcomingList.map(p => (<Row key={p.uid} p={p} bucket="upcoming" />))}
            </div>
          </div>
        )}

        <div className="grid grid-cols-2 gap-2 mt-4">
          <PlantButton onClick={applySelected} disabled={!selectedUids.length}>
            {tab === 'fert' ? '🌾 Log Fertilized' : tab === 'both' ? '💧🌾 Log Both' : '💧 Log Watered'}
          </PlantButton>
          <PlantButton variant="ghost" onClick={goBack}>Back</PlantButton>
        </div>
      </PlantCard>
    </div>
  );
}


/* ===================== QUICK LOG ===================== */
function QuickLogScreen() {
  const { goBack, navigate } = useNavigation();
  const { locations, getPlantsByLocation, search, quickLog, batchWater, batchFertilize, getLatestPhoto } = usePlantData();
  const { isSmall, isDesktop } = useScreenSize();
  const [pickMode, setPickMode] = useState('search');
  const [mode, setMode] = useState('single');
  const [q, setQ] = useState('');
  const [results, setResults] = useState([]);
  const [status, setStatus] = useState(null);
  const [thumbs, setThumbs] = useState({});
  const inFlightRef = useRef(0);
  const [selected, setSelected] = useState({});
  const selectedUids = Object.keys(selected).filter(k => selected[k]);
  const [groupLoc, setGroupLoc] = useState('');
  const [groupPlants, setGroupPlants] = useState([]);
  const [groupLoading, setGroupLoading] = useState(false);
  const [subPreset, setSubPreset] = useState('');
  const [subFree, setSubFree] = useState('');
  const [genusPick, setGenusPick] = useState('');
  const [taxaFree, setTaxaFree] = useState('');
  const [groupSelected, setGroupSelected] = useState({});

  const SUB_PRESETS = [
    { label:'Semi-Hydro', key:'semihydro', aliases:['semi hydro','semi-hydro','semihydro','pon','leca','hydroton','expanded clay','clay ball','stratum','fluval stratum','lava rock','pumice','perlite','zeolite'] },
    { label:'Soil', key:'soil', aliases:['soil','potting','potting mix','mix','soil mix','promix','peat','peat moss','compost','worm cast','castings','manure','humus'] },
    { label:'Coco', key:'coco', aliases:['coco','coir','coconut','coconut coir'] },
    { label:'Bark', key:'bark', aliases:['bark','orchid','orchid bark','pine bark','fir bark','chunk','chunks'] },
    { label:'Mineral', key:'mineral', aliases:['mineral','pumice','perlite','lava','lava rock','scoria','grit','sand','akadama','kanuma','zeolite','diatomite','calcined clay','turface'] },
  ];

  function open(uid) { navigate('plant', { uid }); }
  async function logSingle(uid, kind) {
    setStatus({ type:'loading', message:'Saving...' });
    try {
      if (kind === 'water') await quickLog(uid, { water:true, fertilize:false, repot:false, notes:'' });
      if (kind === 'fert') await quickLog(uid, { water:false, fertilize:true, repot:false, notes:'' });
      setStatus({ type:'success', message:'Saved ✅' });
    } catch (e) { setStatus({ type:'error', message:'Failed' }); }
    setTimeout(() => setStatus(null), 1000);
  }
  function toggle(uid) { setSelected(prev => ({ ...prev, [uid]: !prev[uid] })); }
  function clearSelected(){ setSelected({}); }
  async function multiWater(uids) {
    const list = uids || selectedUids; if (!list.length) return;
    setStatus({ type:'loading', message:'Logging water...' });
    try { await batchWater(list, 'Watered'); setStatus({ type:'success', message:'Saved ✅' }); clearSelected(); setGroupSelected({}); }
    catch(e){ setStatus({ type:'error', message:'Failed' }); }
    setTimeout(() => setStatus(null), 1200);
  }
  async function multiFert(uids) {
    const list = uids || selectedUids; if (!list.length) return;
    setStatus({ type:'loading', message:'Logging fertilize...' });
    try { await batchFertilize(list, 'Fertilized'); setStatus({ type:'success', message:'Saved ✅' }); clearSelected(); setGroupSelected({}); }
    catch(e){ setStatus({ type:'error', message:'Failed' }); }
    setTimeout(() => setStatus(null), 1200);
  }

  useEffect(() => {
    let alive = true;
    const qq = String(q || '').trim();
    const t = setTimeout(async () => {
      try {
        if (!qq || pickMode !== 'search') { if (alive) { setResults([]); clearSelected(); } return; }
        const ticket = ++inFlightRef.current;
        const res = await search(qq, 20);
        if (!alive) return; if (ticket !== inFlightRef.current) return;
        setResults(res || []);
      } catch (e) { if (!alive) return; setResults([]); }
    }, 220);
    return () => { alive = false; clearTimeout(t); };
  }, [q, pickMode]);

  useEffect(() => {
    let alive = true;
    (async () => {
      if (pickMode !== 'group') return;
      if (!groupLoc) { setGroupPlants([]); setGroupSelected({}); return; }
      setGroupLoading(true);
      try {
        const ps = await getPlantsByLocation(groupLoc);
        if (!alive) return;
        setGroupPlants(ps || []);
        setGroupSelected({});
      } catch(e){ if (!alive) return; setGroupPlants([]); setGroupSelected({}); }
      finally { if (alive) setGroupLoading(false); }
    })();
    return () => { alive = false; };
  }, [groupLoc, pickMode]);

  function inferGenus(p){ const g = String(p.genus || '').trim(); if (g) return g; const gs = String(p.gs || '').trim(); if (gs) return gs.split(/\s+/)[0]; const cls = String(p.classification || '').trim(); if (cls) return cls.split(/\s+/)[0]; return ''; }
  const availableGenera = useMemo(() => { const s = new Set(); (groupPlants || []).forEach(p => { const g = inferGenus(p); if (g) s.add(g); }); return Array.from(s).sort((a,b) => a.localeCompare(b)); }, [groupPlants]);
  function substrateText(p){ return (String(p.substrate || '').trim() + ' ' + String(p.medium || '').trim()).trim().toLowerCase(); }
  function matchesSubstrate(p){ const t = substrateText(p); const free = String(subFree || '').trim().toLowerCase(); const preset = SUB_PRESETS.find(x => x.key === subPreset); const presetOk = preset ? preset.aliases.some(a => t.includes(String(a).toLowerCase())) : true; const freeOk = free ? t.includes(free) : true; return presetOk && freeOk; }
  function matchesTaxa(p){ const g = inferGenus(p); if (genusPick && String(g).toLowerCase() !== String(genusPick).toLowerCase()) return false; const q2 = String(taxaFree || '').trim().toLowerCase(); if (!q2) return true; const hay = [p.genus, p.species, p.taxon, p.gs, p.classification, p.primary, p.nickname].map(x => String(x || '')).join(' • ').toLowerCase(); return hay.includes(q2); }
  const groupMatches = useMemo(() => { const list = groupPlants || []; return list.filter(p => matchesSubstrate(p) && matchesTaxa(p)); }, [groupPlants, subPreset, subFree, genusPick, taxaFree]);
  useEffect(() => {
    if (pickMode !== 'group') return;
    const hasManual = Object.keys(groupSelected || {}).length > 0;
    if (hasManual) return;
    const all = {}; (groupMatches || []).forEach(p => { if (p && p.uid) all[String(p.uid)] = true; }); setGroupSelected(all);
  }, [groupMatches, pickMode]);
  function toggleGroup(uid){ const k = String(uid || ''); if (!k) return; setGroupSelected(prev => ({ ...prev, [k]: !prev[k] })); }
  function groupSelectAll(){ const all = {}; (groupMatches || []).forEach(p => { if (p && p.uid) all[String(p.uid)] = true; }); setGroupSelected(all); }
  function groupSelectNone(){ setGroupSelected({}); }
  const groupSelectedUids = useMemo(() => Object.keys(groupSelected || {}).filter(k => groupSelected[k]), [groupSelected, groupMatches]);

  useEffect(() => {
    let alive = true;
    (async () => {
      const list = (pickMode === 'group') ? (groupMatches || []) : (results || []);
      const next = {};
      for (let i = 0; i < list.length; i++) {
        const uid = list[i] && list[i].uid ? String(list[i].uid) : '';
        if (!uid) continue; if (thumbs[uid] || next[uid]) continue;
        try { const res = await getLatestPhoto(uid); if (res && res.ok && res.photo && res.photo.thumbUrl) next[uid] = res.photo.thumbUrl; } catch(e){}
      }
      if (!alive) return;
      if (Object.keys(next).length) setThumbs(prev => ({ ...prev, ...next }));
    })();
    return () => { alive = false; };
  }, [results, groupMatches, pickMode]);

  const pxS = { fontFamily:"'Pixelify Sans', cursive" };

  return (
    <div className={`flex flex-col ${isSmall ? 'p-3' : isDesktop ? 'p-6' : 'p-4'} w-full pb-4 fade-in`}
      style={{ maxWidth: isDesktop ? '1100px' : '680px', margin: '0 auto' }}>
      <PlantCard title="QUICK LOG">
        {status && <StatusMessage type={status.type} message={status.message} />}
        <div className="flex items-center justify-between gap-2 mb-3">
          <div className="flex items-center gap-2">
            <div style={{ ...pxS, fontWeight:900, color:'#4A3020' }}>Mode</div>
            <button type="button" onClick={() => setPickMode('search')}
              className={`px-3 py-2 rounded-lg border-4 ${pickMode==='search' ? 'bg-[#8BB55C] border-[#6B9C3D] text-[#2A4A1A]' : 'bg-white border-[#C8B488] text-[#4A3020]'}`}
              style={{ ...pxS, fontWeight:900, fontSize:'12px' }}>Search</button>
