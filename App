                    style={{ ...pxS, fontSize:'14px' }} />
                </div>
                <div>
                  <label className="block text-[#4A3020] mb-1" style={{ fontFamily:"'Press Start 2P', cursive", fontSize:'10px' }}>Fertilize Every (days)</label>
                  <input value={fertilizeEveryDays} onChange={e => setFertilizeEveryDays(e.target.value.replace(/[^0-9]/g,''))}
                    placeholder="e.g. 30" className="w-full p-3 rounded-lg border-4 border-[#6B4423]"
                    style={{ ...pxS, fontSize:'14px' }} />
                </div>
              </div>
            </div>
          )}
          <div className="mt-4 space-x-2">
            <PlantButton onClick={submit}>✅ Add</PlantButton>
