function BottomNav({ current, navigate, goBack }) {
  const { isDesktop, w } = useScreenSize();
  // Show on any non-desktop — phone OR tablet in portrait
  if (isDesktop) return null;

  const tabs = [
    { id: 'home',      icon: '🏠', label: 'Home'   },
    { id: 'my-plants', icon: '🌿', label: 'Plants'  },
    { id: 'watering',  icon: '💧', label: 'Water'   },
    { id: 'add',       icon: '➕', label: 'Add'     },
    { id: 'quick-log', icon: '⚡', label: 'Log'     },
  ];
  const pxS = { fontFamily:"'Pixelify Sans', cursive" };
  const isHome = current === 'home';

  // Non-tab screens get a back button at left + remaining tabs
  const isTab = tabs.some(t => t.id === current);

  return (
    <div className="shrink-0 flex items-stretch border-t-4 border-[#3d1f00] pb-safe"
      style={{ background:'#2A1200', minHeight: 56 }}>
