/* ===================== TICKER ===================== */
function Ticker() {
  const { homeData } = usePlantData();
  const [now, setNow] = useState(new Date());
  useEffect(() => { const t = setInterval(() => setNow(new Date()), 1000); return () => clearInterval(t); }, []);
  const birthdays = (homeData && homeData.birthdays) ? homeData.birthdays : [];
  const dueNow = (homeData && homeData.dueNow) ? homeData.dueNow : [];
  const msg = [format12h(now), birthdays.length ? `Today's birthdays: ${birthdays.join(', ')}` : `No birthdays today`, dueNow.length ? `Needs water: ${dueNow.length}` : `No plants due now`].join('   •   ');
  return (
    <div className="absolute bottom-3 left-1/2 -translate-x-1/2 z-30 w-[92%] max-w-2xl overflow-hidden">
      <div className="bg-[#6B4423] text-[#F4E4C1] border-4 border-[#4A3020] rounded-xl px-4 py-2 shadow-lg">
        <div className="ticker-track" style={{ fontFamily:"'Press Start 2P', cursive", fontSize:'10px' }}>{msg}   •   {msg}</div>
      </div>
    </div>
  );
}

