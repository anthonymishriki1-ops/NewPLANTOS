/* ===================== PHOTO HELPERS ===================== */
function readFileAsDataUrl(file) {
  return new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onload = () => resolve(String(r.result || ''));
    r.onerror = () => reject(new Error('Failed to read file'));
    r.readAsDataURL(file);
  });
}

function loadImageFromDataUrl(dataUrl) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.onload = () => resolve(img);
    img.onerror = () => reject(new Error('Image decode failed (maybe HEIC)'));
    img.src = dataUrl;
  });
}

async function compressImageToJpegDataUrl(file, maxDim = 1600, quality = 0.82) {
  const dataUrl = await readFileAsDataUrl(file);
  if (!dataUrl.startsWith('data:image/')) throw new Error('Not an image');
  const nameLower = String(file.name || '').toLowerCase();
  if (nameLower.endsWith('.heic') || nameLower.endsWith('.heif') || (file.type && file.type.includes('heic'))) {
    throw new Error('HEIC not supported here. Choose a JPG/PNG.');
  }
  const img = await loadImageFromDataUrl(dataUrl);
  const w0 = img.naturalWidth || img.width;
  const h0 = img.naturalHeight || img.height;
  const scale = Math.min(1, maxDim / Math.max(w0, h0));
  const w = Math.max(1, Math.round(w0 * scale));
  const h = Math.max(1, Math.round(h0 * scale));
  const canvas = document.createElement('canvas');
  canvas.width = w; canvas.height = h;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(img, 0, 0, w, h);
  return canvas.toDataURL('image/jpeg', quality);
}

