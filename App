<script>
  const __BOOT_JSON__ = `<?= JSON.stringify({ baseUrl:(baseUrl||''), mode:(mode||'home'), uid:(uid||''), loc:(loc||''), openAdd:(openAdd||'') }) ?>`;
  window.PLANTOS_BOOT = (function(){ try { return JSON.parse(__BOOT_JSON__); } catch(e){ return {}; } })();

  // ── Measure true available height and stamp it on #root ──
  // This defeats the GAS banner: the banner lives ABOVE the iframe,
  // so window.innerHeight inside the iframe is already the correct usable height.
  // We just need to apply it explicitly so CSS percentages work right.
  function sizeRoot() {
    var root = document.getElementById('root');
    if (!root) return;

    // Prefer visualViewport height on mobile (handles Safari/Chrome browser chrome better)
    var h = (window.visualViewport && window.visualViewport.height) ? window.visualViewport.height : window.innerHeight;

    root.style.height = h + 'px';
    root.style.maxHeight = h + 'px';

    // In some Apps Script container contexts (sidebar/dialog), setHeight may exist. Guard it safely.
    try {
      if (window.google && google.script && google.script.host && typeof google.script.host.setHeight === 'function') {
        google.script.host.setHeight(h);
      }
    } catch (e) {}
  }
  // Run immediately, then on every resize/orientation change
  document.addEventListener('DOMContentLoaded', sizeRoot);
  window.addEventListener('resize', sizeRoot);
  window.addEventListener('orientationchange', function(){ setTimeout(sizeRoot, 250); });
  // Run now too in case DOMContentLoaded already fired
  if (document.readyState !== 'loading') sizeRoot();
</script>

<script type="text/babel">
const { useState, useEffect, useRef, createContext, useContext, useMemo } = React;
const BOOT = window.PLANTOS_BOOT || {};
const HAS_GAS = !!(window.google && google.script && google.script.run);
const DEMO_MODE = !HAS_GAS;

function gasCall(fn, ...args) {
  return new Promise((resolve, reject) => {
    if (!(window.google && google.script && google.script.run)) {
      reject(new Error("Apps Script runtime unavailable"));
      return;
    }
    if (typeof google.script.run[fn] !== "function") {
      reject(new Error(`Backend function not available: ${fn}`));
      return;
    }
    google.script.run
      .withSuccessHandler(resolve)
      .withFailureHandler((err) => reject(new Error((err && err.message) || String(err))))[fn](...args);
  });
}

function useScreenSize() {
  const measure = () => {
    const w = window.innerWidth, h = window.innerHeight;
    return { w, h, isSmall: w < 480, isMobile: w < 768, isTablet: w >= 768 && w < 1024, isDesktop: w >= 1024 };
  };
  const [screenSize, setScreenSize] = useState(measure);
  useEffect(() => {
    const on = () => setScreenSize(measure());
    window.addEventListener('resize', on);
    window.addEventListener('orientationchange', on);
    return () => { window.removeEventListener('resize', on); window.removeEventListener('orientationchange', on); };
  }, []);
  return screenSize;
}

function format12h(date) {
  return date.toLocaleString('en-US', {
    weekday:'short', month:'short', day:'numeric',
    hour:'numeric', minute:'2-digit', second:'2-digit',
    hour12:true
  });
}

function safeUid(raw) {
  const s = String(raw ?? '').trim();
  if (!s) return '';
  const low = s.toLowerCase();
  if (low === 'undefined' || low === 'null' || low === 'nan') return '';
  return s;
}

