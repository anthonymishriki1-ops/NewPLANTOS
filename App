function DiaryScreen({ uid, name }) {
  const { goBack } = useNavigation();
  const { getTimeline } = usePlantData();
  const { isSmall } = useScreenSize();
  const [timeline, setTimeline] = useState([]);
  const [loading, setLoading]   = useState(true);
  const [filter, setFilter]     = useState('all');
  const safe = safeUid(uid);

  useEffect(() => {
    if (!safe) { setLoading(false); return; }
    getTimeline(safe, 200)
      .then(r => { setTimeline(r || []); setLoading(false); })
      .catch(() => setLoading(false));
  }, [safe]);

  const ICONS = { WATER:'💧', FERTILIZE:'🌾', REPOT:'🪴', NOTE:'📝', UPDATE:'✏️', CREATE:'🌱', REPAIR:'🔧', PHOTO:'📸' };
  const COLORS = {
    WATER:    { bg:'#e8f4fd', border:'#2980b9', label:'#1a5276' },
    FERTILIZE:{ bg:'#fef9e7', border:'#f39c12', label:'#7d4e00' },
    REPOT:    { bg:'#fdebd0', border:'#8B4513', label:'#5a2d0c' },
    NOTE:     { bg:'#f9f9f9', border:'#aaa',    label:'#555'    },
    UPDATE:   { bg:'#eaf7ec', border:'#27ae60', label:'#1a5c30' },
    CREATE:   { bg:'#eaf7ec', border:'#27ae60', label:'#1a5c30' },
    PHOTO:    { bg:'#f5eef8', border:'#8e44ad', label:'#5b2c6f' },
    REPAIR:   { bg:'#fdfefe', border:'#717d7e', label:'#333'    },
  };

  const ACTIONS = ['all','WATER','FERTILIZE','REPOT','NOTE','PHOTO','UPDATE'];

  const visible = filter === 'all'
    ? timeline
    : timeline.filter(t => t.action === filter);

  const pxS = { fontFamily:"'Pixelify Sans', cursive" };
  const px8 = { fontFamily:"'Press Start 2P', cursive" };

  return (
    <div className={`flex flex-col ${isSmall ? 'p-3' : 'p-5'} w-full`}
      style={{ maxWidth:'720px', margin:'0 auto', minHeight:'100%' }}>

      {/* Header */}
      <div className="flex items-center gap-3 mb-3">
        <button type="button" onClick={goBack}
          className="px-3 py-2 rounded-lg border-4 border-[#C8B488] bg-[#F4E4C1] hover:bg-[#E8D4A8]"
          style={{ ...pxS, fontWeight:900, color:'#4A3020', fontSize:'12px' }}>← Back</button>
        <div className="flex-1 min-w-0">
          <div style={{ ...px8, fontSize: isSmall ? '10px' : '12px', color:'#4A3020' }}>DIARY</div>
          {name && <div style={{ ...pxS, fontSize:'13px', color:'#6B4423', fontWeight:800 }} className="truncate">{name}</div>}
        </div>
        <div style={{ ...pxS, fontSize:'12px', color:'#aaa', fontWeight:800 }}>
          {visible.length} {filter !== 'all' ? filter.toLowerCase() : 'entries'}
        </div>
      </div>

      {/* Filter chips */}
      <div className="flex gap-2 mb-3 overflow-x-auto pb-1" style={{ scrollbarWidth:'none' }}>
        {ACTIONS.map(a => (
          <button key={a} type="button"
            onClick={() => setFilter(a)}
            className={`shrink-0 px-3 py-1 rounded-full border-2 transition-all ${filter === a
              ? 'bg-[#6B4423] border-[#6B4423] text-white'
              : 'bg-white border-[#C8B488] text-[#4A3020] hover:bg-[#F4E4C1]'}`}
            style={{ ...pxS, fontWeight:900, fontSize:'11px' }}>
            {ICONS[a] || ''} {a === 'all' ? 'All' : a.charAt(0) + a.slice(1).toLowerCase()}
          </button>
        ))}
      </div>

      {/* Scrolling diary */}
      <div className="scroll-y space-y-2 pb-4" style={{ maxHeight:'60vh' }}>
        {loading && (
          <div className="bg-white rounded-xl border-4 border-[#C8B488] p-4 text-center"
            style={{ ...pxS, color:'#aaa' }}>Loading...</div>
        )}
        {!loading && visible.length === 0 && (
          <div className="bg-white rounded-xl border-4 border-[#C8B488] p-6 text-center"
            style={{ ...pxS, color:'#aaa', fontSize:'13px' }}>No entries yet.</div>
        )}
        {!loading && visible.map((t, i) => {
          const c = COLORS[t.action] || COLORS.NOTE;
          return (
            <div key={i} className="rounded-xl border-4 p-3 shadow-sm"
              style={{ background: c.bg, borderColor: c.border }}>
              <div className="flex items-start gap-3">
                <div style={{ fontSize:'22px', lineHeight:1, marginTop:'2px' }}>
                  {ICONS[t.action] || '•'}
                </div>
                <div className="flex-1 min-w-0">
                  {t.action === 'NOTE'
                    ? <>
                        <div style={{ ...pxS, fontSize:'10px', color:'#aaa', flexShrink:0, marginBottom:4 }}>{t.ts}</div>
                        <div style={{ ...pxS, fontSize:'14px', color:'#4A3020', lineHeight:1.5 }}>{t.details || '(note)'}</div>
                      </>
                    : <>
                        <div className="flex items-baseline justify-between gap-2 mb-1">
                          <div style={{ ...px8, fontSize:'9px', color: c.label }}>{t.action}</div>
                          <div style={{ ...pxS, fontSize:'10px', color:'#aaa', flexShrink:0 }}>{t.ts}</div>
                        </div>
                        {t.details && <div style={{ ...pxS, fontSize:'13px', color:'#4A3020', lineHeight:1.5 }}>{t.details}</div>}
                      </>
                  }
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}


