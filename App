    .hover-lift:hover { transform: translateY(-2px); box-shadow: 0 8px 18px rgba(74,48,32,0.18); }

    .btn-press { transition: all 0.12s cubic-bezier(0.4,0,0.2,1); }
    .btn-press:active:not(:disabled) { transform: scale(0.96) translateY(2px); box-shadow: 0 2px 4px rgba(74,48,32,0.25); }

    .btn-gradient { position: relative; overflow: hidden; }
    .btn-gradient::before {
      content: ''; position: absolute; top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
      transition: left 0.45s ease;
