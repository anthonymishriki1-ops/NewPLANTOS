  <style>
    *, *::before, *::after {
      margin: 0; padding: 0; box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      width: 100%;
      /* Use dvh (dynamic viewport height) so browser chrome is excluded.
         Falls back through svh → vh for older browsers. */
      height: 100dvh;
      height: 100svh;
      height: 100vh;
      overflow: hidden;
      overscroll-behavior: none;
      -webkit-touch-callout: none;
      background: #8BC34A;
    }

    /* #root uses JS-measured innerHeight so GAS banner doesn't affect us */
    #root {
      width: 100%;
      /* height set by JS below — falls back to 100% */
      height: 100%;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* Kill 300ms tap delay */
    button, a, [role="button"] { touch-action: manipulation; }

    /* Kill iOS input zoom — inputs must render ≥16px */
    input, textarea, select {
      font-size: 16px !important;
    }

    /* Momentum scroll for inner scroll areas */
    .scroll-y {
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: contain;
    }

    @keyframes marquee {
      0%   { transform: translateX(100%); }
      100% { transform: translateX(-100%); }
    }
    .ticker-track {
      display: inline-block;
      white-space: nowrap;
      padding-left: 100%;
      animation: marquee 18s linear infinite;
    }

    /* Safe area insets for notch / home indicator */
    .pb-safe { padding-bottom: max(8px, env(safe-area-inset-bottom)); }

    /* ══════════════════════════════════════════════════════
       JAZZ ENHANCEMENTS
    ══════════════════════════════════════════════════════ */

    .paper-texture { position: relative; }
    .paper-texture::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      background-image:
        repeating-linear-gradient(90deg, transparent 0px, transparent 2px, rgba(107,68,35,0.025) 2px, rgba(107,68,35,0.025) 4px),
        repeating-linear-gradient(0deg,  transparent 0px, transparent 2px, rgba(107,68,35,0.025) 2px, rgba(107,68,35,0.025) 4px);
