function demoIso_(d) {
  const z = (n) => String(n).padStart(2,'0');
  return `${d.getFullYear()}-${z(d.getMonth()+1)}-${z(d.getDate())}`;
}
function demoAddDays_(isoStr, days) {
  const d = new Date(String(isoStr||'').trim());
  if (isNaN(d)) return '';
  d.setDate(d.getDate() + (Number(days)||0));
  return demoIso_(d);
}
function demoPrimary_(p) {
  const nn = String(p.nickname||'').trim();
  if (nn) return nn;
  const g = String(p.genus||'').trim();
  const t = String(p.species||p.taxon||'').trim();
  const s = (g && t) ? `${g} ${t}` : (g || t || p.uid);
  return cleanDisplayName(s);
}
function demoRecomputeDue_(p) {
  const every = Number(p.everyDays||0);
  if (!every || !p.lastWatered) return '';
  return demoAddDays_(p.lastWatered, every);
}
function demoRecomputeFertDue_(p) {
  const every = Number(p.fertilizeEveryDays||0);
  if (!every || !p.lastFertilized) return '';
  return demoAddDays_(p.lastFertilized, every);
}
function demoNowStamp_() {
  const d = new Date();
  const pad = (n)=>String(n).padStart(2,'0');
  return `${demoIso_(d)} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

// Legacy alias used internally
function cleanDisplayName_(s){ return cleanDisplayName(s); }

function normStr(v){ return String(v || '').trim().toLowerCase(); }

function cleanDisplayName(s){
  const raw = String(s || '').trim();
  if (!raw) return '';
  const parts = raw.split(/\s+/);
  const out = [];
  for (let i=0;i<parts.length;i++){
    const w = parts[i];
    if (!w) continue;
    if (out.length && out[out.length-1].toLowerCase() === w.toLowerCase()) continue;
    out.push(w);
  }
  return out.join(' ').replace(/\s{2,}/g,' ').trim();
}

function getTaxLine(plant){
  if (!plant) return '';
  const gs = String(plant.gs || '').trim();
  const cls = String(plant.classification || '').trim();
  const genus = String(plant.genus || '').trim();
  const taxon = String(plant.species || plant.taxon || '').trim();
  if (gs && /\s/.test(gs)) return gs;
  if (cls && /\s/.test(cls)) return cls;
  const combo = [genus, taxon].filter(Boolean).join(' ').trim();
  if (combo && /\s/.test(combo)) return combo;
  return gs || combo || cls || '';
}

/* ===================== NAV ===================== */
const NavigationContext = createContext(undefined);

function parseStartRouteFromBoot(){
  const openAdd = String(BOOT.openAdd || '').trim().toLowerCase();
  if (openAdd === '1' || openAdd === 'true' || openAdd === 'add') return { screen:'add', params:{} };
  const modeLower = String(BOOT.mode || '').trim().toLowerCase();
  const uid = safeUid(BOOT.uid);
  if (uid && modeLower === 'plant') return { screen:'plant', params:{ uid } };
  const modeMap = {
    home:'home', plant:'plant', add:'add', 'my-plants':'my-plants', plants:'my-plants',
    locations:'my-plants', watering:'watering', 'quick-log':'quick-log', quicklog:'quick-log',
    'plant-log':'plant-log', log:'plant-log', spec:'spec',
    'batch-water':'batch-water', 'batch-fertilize':'batch-fertilize'
  };
  const scr = modeMap[modeLower] || 'home';
  return { screen: scr, params: (scr === 'plant' && uid) ? { uid } : {} };
}

function NavigationProvider({ children }) {
  const startRoute = useMemo(() => parseStartRouteFromBoot(), []);
  const [route, setRoute] = useState(startRoute);
  const [history, setHistory] = useState([startRoute]);

  useEffect(() => {
    try {
      if (!(window.google && google.script && google.script.url && typeof google.script.url.getLocation === 'function')) return;
      google.script.url.getLocation((loc) => {
        try {
          const p = (loc && loc.parameter) ? loc.parameter : {};
          const modeRaw = String(p.mode || '').trim();
          const uidParam = safeUid(p.uid);
          let uidFromMode = '';
          const m = modeRaw.match(/^uid(\d+)$/i);
          if (m && m[1]) uidFromMode = m[1];
          const finalUid = uidParam || uidFromMode;
          if (finalUid) { const next = { screen:'plant', params:{ uid: finalUid } }; setRoute(next); setHistory([next]); return; }
          const ml = modeRaw.toLowerCase();
          if (ml === 'locations' || ml === 'plants' || ml === 'my-plants') { const next = { screen:'my-plants', params:{} }; setRoute(next); setHistory([next]); return; }
        } catch(e){}
      });
    } catch(e){}
  }, []);

  const navigate = (screen, params={}) => {
    const next = { screen, params: params || {} };
    setRoute(next);
    setHistory(prev => [...prev, next]);
  };

  const goBack = () => {
    setHistory(prev => {
      if (prev.length <= 1) return prev;
      const h = prev.slice(0, prev.length - 1);
      const last = h[h.length - 1];
      setRoute(last);
      return h;
    });
  };

  return (
    <NavigationContext.Provider value={{ route, navigate, goBack, canGoBack: history.length > 1 }}>
      {children}
    </NavigationContext.Provider>
  );
}

function useNavigation() {
  const ctx = useContext(NavigationContext);
  if (!ctx) throw new Error('useNavigation must be used within NavigationProvider');
  return ctx;
}

